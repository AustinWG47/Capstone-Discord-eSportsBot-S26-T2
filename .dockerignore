!.env.template
token.json
service_account.json

# Logs
**/*.log
Log/

# Editor / IDE
.vscode/
.idea/
*.swp
*.bak

# Databases (except the seeded one, if any)
*.db
!main_db.db

# Spreadsheets (except the seeded one, if any)
*.xlsx
!PlayerStats.xlsx

